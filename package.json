{
  "name": "react-refsignal",
  "version": "1.3.0",
  "description": "A lightweight React hook library for managing and subscribing to signals within refs, enabling efficient updates and notifications without unnecessary renders.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.js"
    },
    "./broadcast": {
      "types": "./dist/broadcast.d.ts",
      "import": "./dist/broadcast.mjs",
      "require": "./dist/broadcast.js"
    },
    "./persist": {
      "types": "./dist/persist.d.ts",
      "import": "./dist/persist.mjs",
      "require": "./dist/persist.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit -p tsconfig.eslint.json",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "prettier:fix": "prettier --write 'src/**/*.{ts,tsx}'",
    "prepublishOnly": "npm run typecheck && npm run build",
    "size": "size-limit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jav974/react-refsignal.git"
  },
  "keywords": [
    "react",
    "ref",
    "signal",
    "state"
  ],
  "author": "jav974",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jav974/react-refsignal/issues"
  },
  "homepage": "https://github.com/jav974/react-refsignal#readme",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.5.3",
    "size-limit": "^11.2.0",
    "ts-jest": "^29.3.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "size-limit": [
    {
      "path": "dist/index.js"
    }
  ]
}
